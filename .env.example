# ShikshaSetu - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# App Config
REACT_APP_APP_NAME=ShikshaSetu
REACT_APP_UPI_ID=shikshasetu@upi
REACT_APP_SUPPORT_EMAIL=support@shikshasetu.in

# Optional: Razorpay (for future payment integration)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_key_here
