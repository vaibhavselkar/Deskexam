# ShikshaSetu - Environment Variables Template
# Copy this file to .env.local (frontend) and fill in your values.
# For the backend, copy to backend/.env

# ─── Frontend (.env.local) ────────────────────────────────────────────────────

# URLs
REACT_APP_FRONTEND_URL=https://your-app.vercel.app
REACT_APP_API_URL=https://your-app.vercel.app/api

# App Config
REACT_APP_APP_NAME=ShikshaSetu
REACT_APP_UPI_ID=your-upi-id@bank
REACT_APP_SUPPORT_EMAIL=support@yourdomain.com

# ─── Backend (backend/.env) ───────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/shikshasetu

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Allowed frontend origin for CORS (set to your Vercel URL in production)
FRONTEND_URL=https://your-app.vercel.app

# Server port (Vercel ignores this; used for local dev only)
PORT=5000
